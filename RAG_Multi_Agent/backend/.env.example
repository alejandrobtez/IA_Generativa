# --- 1. LLM: Azure OpenAI (gpt-4o) ---
# Azure AI Foundry -> tu proyecto con gpt-4o -> Management Center -> Keys & Endpoint
AZURE_OPENAI_CHAT_KEY=your_chat_key_here
AZURE_OPENAI_CHAT_ENDPOINT=https://<your-chat-resource>.openai.azure.com
AZURE_OPENAI_CHAT_API_VERSION=2024-02-01
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o

# --- 2. Embeddings: Azure OpenAI (text-embedding-3-small) ---
# Azure AI Foundry -> tu proyecto con embeddings -> Management Center -> Keys & Endpoint
AZURE_OPENAI_EMBEDDING_KEY=your_embedding_key_here
AZURE_OPENAI_EMBEDDING_ENDPOINT=https://<your-embedding-resource>.services.ai.azure.com
AZURE_OPENAI_EMBEDDING_API_VERSION=2024-05-01-preview
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# --- 3. Azure AI Search (Vector Store) ---
# Azure AI Search -> Settings -> Keys (Admin Key) y Overview (URL)
# El código crea un índice por asistente con este prefijo: asistente-1, asistente-2, ...
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_KEY=your_admin_key_here
AZURE_SEARCH_INDEX_NAME=asistente

# --- 4. Azure Blob Storage (opcional, no usado en versión actual) ---
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_STORAGE_CONTAINER_NAME=ragcontainer

# --- 5. Almacenamiento local ---
DATABASE_URL=sqlite:///./rag_app.db
UPLOAD_DIR=./uploads
